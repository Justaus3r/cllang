options {
    STATIC = true;
}

PARSER_BEGIN(CLLang)
package CLLang;

public class CLLang {
    public static SymbolTable symTb;
    public static SemanticAnalysis sa;

    public static void main(String argv[]) throws ParseException {
        symTb = new SymbolTable();
        sa = new SemanticAnalysis();

        CLLang parser = new CLLang(System.in);
        parser.Start();
        symTb.printSymbolTable();
    }

}

PARSER_END(CLLang)

SKIP: {
  "\n"
| "\r\n"
| " "
| "//"
}

TOKEN:{
  <PROGSTART: "startProgram">
| <ENDPROG: "endProgram">
| <COLON: ":">
| <DOT: ".">
| <VARIABLESTART: "variables">
| <CODESTART: "code">
| <LOOPSTART: "loopif">
| <LOOPHOLDS: "holds">
| <LOOPEND: "endloop">
| <SWITCHFOR: "switchfor">
| <SWITCHCASE: "case">
| <SWITCHOTHER: "other">
| <ENDSWITCHFOR: "endswitchfor">
| <INT_TYPE: "int">
| <FLOAT_TYPE: "float">
| <STRING_TYPE: "string">
| <PrintOut: "outString">
| <DIGIT: (["0" - "9"]) >
| <DECIMAL: ["0" - "9"] <DOT> (["0" - "9"])+>
| <REAL: (["1" - "9"] (<DIGIT>)*) >
| <STRING: "\"" (["a" - "z", "0" - "9" , "A" - "Z"])+ "\"">
| <IDENTIFIER: ["a" - "z", "A" - "Z", "_"] ( ["a" - "z", "A" - "Z", "_", "0" - "9"] )* >
| <SEMICOLON: ";">
| <ASSIGNMENT: "=">
| <ISEQUALS: "==">
| <GREATERTHAN: ">">
| <SMALLERTHAN: "<">
| <GREATEROREQUAL: ">=">
| <SMALLEROREQUAL: "<=">
| <COMMA: ",">
| <OpenParenthesis: "(">
| <CloseParenthesis: ")">
| <PLUS: "+">
| <MINUS: "-">
| <ASTERISK: "*">
| <DIVIDE: "/">
}


void Start() #Start : {}{

  ProgramBlockStart()
   VariableBlock()
   CodeBlock()
  ProgramBlockEnd()
}

void ProgramBlockStart() #ProgramBlockStart : {}{
 <PROGSTART> 
}

void ProgramBlockEnd() #ProgramBlockEnd : {}{
 <ENDPROG> 
}

void VariableBlock() #VariableBlock : {}{
 VariableBlockStart()
 VariableDeclaration()
}

void VariableBlockStart() #VariableBlockStart : {}{
 <VARIABLESTART> <COLON>
}

Token VariableDataTypes() #VariableBlockStart :
{
  Token t;
}
{
  t=<INT_TYPE> {return t;} 
| t=<FLOAT_TYPE> {return t;}
| t=<STRING_TYPE> {return t;}
 
}

void VariableDeclaration() #VariableDeclaration:
{
Token dataType, identifier;
}

{
    (dataType=VariableDataTypes() identifier=<IDENTIFIER> 
        {
            symTb.put(identifier.image, dataType.image);
        }
    
    ( <ASSIGNMENT> (<REAL> | <STRING> | <DIGIT> | <DECIMAL>) )? 

    (<COMMA> identifier=<IDENTIFIER>
        {
            symTb.put(identifier.image, symTb.lastValue());
        }

    ( <ASSIGNMENT> (<REAL> | <STRING> | <DIGIT> | <DECIMAL>) )? )*  <SEMICOLON>)+

}

void CodeBlock() #CodeBlock : {}{
 CodeBlockStart()
 CodeBlockBody()
}

void CodeBlockStart() #CodeBlockStart : {}{
 <CODESTART> <COLON>
}

void OutStmt() #OutStmt : {}{
  <PrintOut> <OpenParenthesis> (<IDENTIFIER> | <STRING> | <REAL> | <DECIMAL> ) <CloseParenthesis> <SEMICOLON>
}

void AirhtemicOperators() #AirhtemicOperators : {}{
  <PLUS>
| <MINUS>
| <ASTERISK>
| <DIVIDE>
}

void ArithemicExpression() #ArithemicExpression : {}{
 (<IDENTIFIER> | <DIGIT> | <REAL> | <DECIMAL> )
    AirhtemicOperators()
 (<IDENTIFIER> | <DIGIT> | <REAL> | <DECIMAL> )
}

void AssignmentStmt() #AssignmentStmt :
{
Token t;
String identifierName, tokenType;
String declaredType;
}
{
    t=<IDENTIFIER> { identifierName=t.image; } <ASSIGNMENT> (t=<REAL> | t=<STRING> | t=<DIGIT> | t=<DECIMAL> | ArithemicExpression()) <SEMICOLON>
    {
        tokenType = sa.infereType(t.image);
        declaredType = symTb.get(identifierName);
        System.out.println("Declared Type: " + declaredType + ", actual Type: " + tokenType);
        if(tokenType != declaredType) {
            throw new AssertionError("Type mismatch at lno:" + t.beginLine + ",col:" + t.beginColumn + ". Expected value of type '" + declaredType + "' but got of type ' " + tokenType + "'. ");
        }
    }
}

void ConditionalStmt() #ConditionalStmt : {} {
  <IDENTIFIER> (<GREATERTHAN> | <SMALLERTHAN> | <GREATEROREQUAL> | <SMALLEROREQUAL>) (<REAL> | <STRING>)
}

void LoopStmt() #LoopStmt : {}{
  <LOOPSTART> ConditionalStmt() <LOOPHOLDS>
  (AssignmentStmt())*
  <LOOPEND>
}

void SwitchCaseBody() #SwitchCaseBody : {}{
  ((<SWITCHCASE> | <SWITCHOTHER>) (<REAL> | <DIGIT> | <STRING>) <COLON> ( AssignmentStmt() )+ )+
}

void SwitchCaseStmt() #SwitchCaseStmt : {}{
  <SWITCHFOR> ( <IDENTIFIER> | <REAL> | <DIGIT>) 
  SwitchCaseBody()
  <ENDSWITCHFOR>
}

void Stmts() #Stmts : {}{
  AssignmentStmt()
| OutStmt()
| LoopStmt()
| SwitchCaseStmt()
}

void CodeBlockBody() #CodeBlockBody : {}{
  ( Stmts() )*
}
